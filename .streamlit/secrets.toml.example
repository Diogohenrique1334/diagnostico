# Exemplo de secrets para o Streamlit Community Cloud.
#
# - No Cloud: cole o conteúdo abaixo (com os valores reais) em
#   App settings -> Secrets.
# - Localmente (opcional): copie para .streamlit/secrets.toml (NÃO commitar).
#
# Use o formato asyncpg (ssl=require). Mesmo valor do .env.

DATABASE_URL = "postgresql+asyncpg://USUARIO:SENHA@HOST-pooler.REGIAO.azure.neon.tech/neondb?ssl=require"
DEBUG = false
